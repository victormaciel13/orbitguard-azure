{
  "$schema": "https://json.schemastore.org/staticwebapp.config.json",
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "*.css", "*.js", "*.png"]
  },
  "platform": {
    "apiRuntime": "python:3.11"
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html"
    }
  }
}
